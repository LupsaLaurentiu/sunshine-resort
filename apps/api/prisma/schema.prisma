generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  PENDING_APPROVAL
  APPROVED_AWAITING_PAYMENT
  CONFIRMED
  REJECTED
  CANCELLED
  EXPIRED
  CHECKED_IN
  CHECKED_OUT
}

enum ReservationSource {
  DIRECT_WEBSITE
  MANUAL_ADMIN
  BOOKING_COM
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  FULL
  REMAINING_BALANCE
  MODIFICATION_DIFFERENCE
}

enum PaymentProvider {
  STRIPE
  CASH
  POS
  BANK_TRANSFER
  MANUAL
}

enum ReservationChangeStatus {
  PENDING_APPROVAL
  APPROVED_AWAITING_PAYMENT
  APPLIED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ExternalCalendarSource {
  BOOKING_COM
}

enum Locale {
  RO
  EN
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  createdReservations   Reservation[]       @relation("ReservationCreatedBy")
  approvedReservations  Reservation[]       @relation("ReservationApprovedBy")
  approvedChanges       ReservationChange[] @relation("ReservationChangeApprovedBy")
  rejectedChanges       ReservationChange[] @relation("ReservationChangeRejectedBy")
  createdBlockedPeriods BlockedPeriod[]     @relation("BlockedPeriodCreatedBy")
  createdRatePeriods    RatePeriod[]        @relation("RatePeriodCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomType {
  id            String  @id @default(cuid())
  nameRo        String
  nameEn        String
  slug          String  @unique
  descriptionRo String?
  descriptionEn String?

  weekdayBasePrice Decimal @db.Decimal(10, 2)
  weekendBasePrice Decimal @db.Decimal(10, 2)

  maxAdults Int
  sizeSqm   Int?
  isActive  Boolean @default(true)

  rooms            Room[]
  reservationRooms ReservationRoom[]
  ratePeriods      RatePeriod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Room {
  id         String @id @default(cuid())
  name       String
  code       String @unique
  roomTypeId String
  floor      Int?

  tvDeviceId String? @unique
  isActive   Boolean @default(true)

  roomType          RoomType           @relation(fields: [roomTypeId], references: [id])
  reservationRooms  ReservationRoom[]
  blockedPeriods    BlockedPeriod[]
  externalCalendars ExternalCalendar[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomTypeId])
  @@index([isActive])
}

model Guest {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String
  country   String?
  notes     String?

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Reservation {
  id      String            @id @default(cuid())
  guestId String
  status  ReservationStatus @default(PENDING_APPROVAL)
  source  ReservationSource @default(DIRECT_WEBSITE)
  locale  Locale            @default(RO)

  checkInDate  DateTime @db.Date
  checkOutDate DateTime @db.Date
  checkInTime  String   @default("14:00")
  checkOutTime String   @default("10:00")

  adults Int
  nights Int

  subtotalPrice     Decimal @db.Decimal(10, 2)
  discountAmount    Decimal @default(0) @db.Decimal(10, 2)
  totalPrice        Decimal @db.Decimal(10, 2)
  depositPercentage Decimal @default(50) @db.Decimal(5, 2)
  depositAmount     Decimal @db.Decimal(10, 2)
  paidAmount        Decimal @default(0) @db.Decimal(10, 2)

  isComplimentary Boolean @default(false)

  createdByAdminId  String?
  approvedByAdminId String?

  adminNotes String?
  guestNotes String?

  rejectionReason    String?
  cancellationReason String?

  approvalExpiresAt DateTime?
  paymentExpiresAt  DateTime?

  approvedAt   DateTime?
  rejectedAt   DateTime?
  cancelledAt  DateTime?
  confirmedAt  DateTime?
  checkedInAt  DateTime?
  checkedOutAt DateTime?

  guest           Guest  @relation(fields: [guestId], references: [id])
  createdByAdmin  Admin? @relation("ReservationCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  approvedByAdmin Admin? @relation("ReservationApprovedBy", fields: [approvedByAdminId], references: [id], onDelete: SetNull)

  rooms    ReservationRoom[]
  payments Payment[]
  changes  ReservationChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guestId])
  @@index([status])
  @@index([source])
  @@index([checkInDate, checkOutDate])
  @@index([createdByAdminId])
  @@index([approvedByAdminId])
  @@index([approvalExpiresAt])
  @@index([paymentExpiresAt])
}

model ReservationRoom {
  id            String  @id @default(cuid())
  reservationId String
  roomTypeId    String
  roomId        String?

  adults Int

  weekdayNights Int @default(0)
  weekendNights Int @default(0)
  nights        Int

  weekdayPricePerNight Decimal @db.Decimal(10, 2)
  weekendPricePerNight Decimal @db.Decimal(10, 2)
  subtotal             Decimal @db.Decimal(10, 2)

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  roomType    RoomType    @relation(fields: [roomTypeId], references: [id])
  room        Room?       @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@unique([reservationId, roomId])
  @@index([reservationId])
  @@index([roomTypeId])
  @@index([roomId])
}

model RatePeriod {
  id               String  @id @default(cuid())
  roomTypeId       String
  createdByAdminId String?

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  weekdayPrice Decimal @db.Decimal(10, 2)
  weekendPrice Decimal @db.Decimal(10, 2)

  isPromotion Boolean @default(false)

  originalWeekdayPrice Decimal? @db.Decimal(10, 2)
  originalWeekendPrice Decimal? @db.Decimal(10, 2)

  titleRo String?
  titleEn String?

  isActive Boolean @default(true)

  roomType       RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  createdByAdmin Admin?   @relation("RatePeriodCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomTypeId, startDate, endDate])
  @@index([isActive])
  @@index([createdByAdminId])
}

model ReservationChange {
  id            String                  @id @default(cuid())
  reservationId String
  status        ReservationChangeStatus @default(PENDING_APPROVAL)

  requestedCheckInDate  DateTime @db.Date
  requestedCheckOutDate DateTime @db.Date

  oldCheckInDate  DateTime @db.Date
  oldCheckOutDate DateTime @db.Date

  oldSubtotalPrice Decimal @db.Decimal(10, 2)
  newSubtotalPrice Decimal @db.Decimal(10, 2)
  priceDifference  Decimal @db.Decimal(10, 2)

  amountDue      Decimal @default(0) @db.Decimal(10, 2)
  retainedAmount Decimal @default(0) @db.Decimal(10, 2)

  approvedByAdminId String?
  rejectedByAdminId String?

  guestReason     String?
  adminNotes      String?
  rejectionReason String?

  approvalExpiresAt DateTime?
  paymentExpiresAt  DateTime?

  approvedAt  DateTime?
  rejectedAt  DateTime?
  appliedAt   DateTime?
  expiredAt   DateTime?
  cancelledAt DateTime?

  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  approvedByAdmin Admin?      @relation("ReservationChangeApprovedBy", fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  rejectedByAdmin Admin?      @relation("ReservationChangeRejectedBy", fields: [rejectedByAdminId], references: [id], onDelete: SetNull)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reservationId])
  @@index([status])
  @@index([approvalExpiresAt])
  @@index([paymentExpiresAt])
}

model Payment {
  id                  String  @id @default(cuid())
  reservationId       String
  reservationChangeId String?

  type     PaymentType
  status   PaymentStatus   @default(PENDING)
  provider PaymentProvider @default(STRIPE)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("RON")

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  providerEventId         String? @unique
  paymentUrl              String?

  paidAt      DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?
  refundedAt  DateTime?

  failureReason String?

  reservation       Reservation        @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationChange ReservationChange? @relation(fields: [reservationChangeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reservationId])
  @@index([reservationChangeId])
  @@index([status])
  @@index([type])
}

model BlockedPeriod {
  id               String  @id @default(cuid())
  roomId           String
  createdByAdminId String?

  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?

  room           Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdByAdmin Admin? @relation("BlockedPeriodCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId, startDate, endDate])
  @@index([createdByAdminId])
}

model ExternalCalendar {
  id     String                 @id @default(cuid())
  roomId String
  source ExternalCalendarSource @default(BOOKING_COM)

  importUrl   String
  exportToken String  @unique
  isActive    Boolean @default(true)

  lastSyncedAt  DateTime?
  lastSyncError String?

  room   Room                    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  events ExternalCalendarEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, source])
  @@index([isActive])
}

model ExternalCalendarEvent {
  id                 String @id @default(cuid())
  externalCalendarId String
  externalUid        String

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  summary     String?
  description String?

  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  cancelledAt DateTime?

  externalCalendar ExternalCalendar @relation(fields: [externalCalendarId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([externalCalendarId, externalUid])
  @@index([externalCalendarId])
  @@index([startDate, endDate])
}
